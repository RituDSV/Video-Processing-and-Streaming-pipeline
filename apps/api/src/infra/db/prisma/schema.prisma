datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum VideoStatus {
  UPLOAD_PENDING
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum VideoRenditionType {
  MP4
  HLS
}

model Video {
  id           String      @id @default(uuid())
  originalName String
  mimeType     String
  sizeBytes    BigInt
  sourcePath   String
  status       VideoStatus

  durationSec Float?
  width       Int?
  height      Int?

  renditions VideoRendition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoRendition {
  id      String             @id @default(uuid())
  type    VideoRenditionType
  path    String // path or URL
  videoId String

  video Video @relation(fields: [videoId], references: [id])

  createdAt DateTime @default(now())

  @@index([videoId])
}

model VideoDeadLetter {
  id           String   @id @default(uuid())
  videoId      String
  topic        String   // e.g. "video.uploaded"
  errorMessage String
  retryCount   Int
  payload      Json     // full event payload for reprocessing
  resolvedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([videoId])
}
